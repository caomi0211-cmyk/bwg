// ==========================================
// 语音助手 (Web Speech API) - 运河意识
// ==========================================
const VoiceManager = {
    synth: window.speechSynthesis,
    voice: null,
    enabled: true,
    isSequencing: false,     
    sequenceQueue: [],       
    onLineStart: null,       
    activeUtterance: null, 

    init() {
        const loadVoices = () => {
            const voices = this.synth.getVoices();
            this.voice = voices.find(v => v.lang.includes('zh') && v.localService && (v.name.includes('Xiaoxiao') || v.name.includes('晓晓') || v.name.includes('Yaoyao') || v.name.includes('Tingting')))
                      || voices.find(v => v.lang.includes('zh') && v.localService)
                      || voices.find(v => v.lang.includes('zh') && (v.name.includes('Xiaoxiao') || v.name.includes('Online')))
                      || voices.find(v => v.lang.includes('zh') || v.name.includes('Chinese')) 
                      || voices[0];
        };
        loadVoices();
        if (this.synth.onvoiceschanged !== undefined) {
            this.synth.onvoiceschanged = loadVoices;
        }
    },
    speak(text) {
        if (!this.enabled || !text) return;
        this.stop(); 

        let rhythmicText = text.replace(/——/g, '，');
        const utterance = new SpeechSynthesisUtterance(rhythmicText);
        if (this.voice) utterance.voice = this.voice;
        utterance.lang = 'zh-CN';
        
        utterance.rate = 1.25;  
        utterance.pitch = 0.4;  
        utterance.volume = 1.0; 
        
        this.activeUtterance = utterance; 
        this.synth.speak(utterance);
    },
    speakSequence(lines, onLineStart) {
        if (!this.enabled || !lines || lines.length === 0) return;
        this.stop();
        this.isSequencing = true;
        this.sequenceQueue = [...lines]; 
        this.onLineStart = onLineStart;
        this.playNextInSequence();
    },
    playNextInSequence() {
        if (!this.isSequencing || this.sequenceQueue.length === 0) return;
        const text = this.sequenceQueue.shift();
        
        if (this.onLineStart) this.onLineStart(text);

        const utterance = new SpeechSynthesisUtterance(text.replace(/——/g, '，'));
        if (this.voice) utterance.voice = this.voice;
        utterance.lang = 'zh-CN';
        
        utterance.rate = 1.25;  
        utterance.pitch = 0.4;  
        utterance.volume = 1.0; 
        
        this.activeUtterance = utterance; 

        utterance.onend = () => {
            if (this.isSequencing) {
                setTimeout(() => { this.playNextInSequence(); }, 200); 
            }
        };
        utterance.onerror = () => {
            if (this.isSequencing) {
                setTimeout(() => { this.playNextInSequence(); }, 200); 
            }
        };

        this.synth.speak(utterance);
    },
    stop() {
        this.isSequencing = false;
        this.sequenceQueue = [];
        this.activeUtterance = null;
        this.synth.cancel();
    },
    toggle() {
        this.enabled = !this.enabled;
        if (!this.enabled) this.stop();
        const indicator = document.getElementById('voice-status');
        if (this.enabled) indicator.classList.add('active');
        else indicator.classList.remove('active');
    }
};
VoiceManager.init();
document.getElementById('toggle-voice').addEventListener('click', () => VoiceManager.toggle());

