const videoElement = document.querySelector('.input_video');
const handCursor = document.getElementById('hand-cursor');

function onResults(results) {
    document.getElementById('camera-status').classList.add('active');
    if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
        document.getElementById('tracking-status').classList.add('active');
        const landmarks = results.multiHandLandmarks[0];
        AppState.hand.detected = true;
        const cursorX = (1 - landmarks[9].x) * window.innerWidth;
        const cursorY = landmarks[9].y * window.innerHeight;
        AppState.hand.screenX = cursorX; AppState.hand.screenY = cursorY;
        handCursor.style.opacity = 1; handCursor.style.left = `${cursorX}px`; handCursor.style.top = `${cursorY}px`;

        let currentGesture = 'None';
        
        const wrist = landmarks[0];
        const thumbTip = landmarks[4];
        const indexTip = landmarks[8];
        const indexMcp = landmarks[5]; 
        const middleTip = landmarks[12];
        const middleMcp = landmarks[9]; 

        const distPinch = Math.hypot(thumbTip.x - indexTip.x, thumbTip.y - indexTip.y);
        const dTip8 = Math.hypot(indexTip.x - wrist.x, indexTip.y - wrist.y);
        const dMcp5 = Math.hypot(indexMcp.x - wrist.x, indexMcp.y - wrist.y);
        const dTip12 = Math.hypot(middleTip.x - wrist.x, middleTip.y - wrist.y);
        const dMcp9 = Math.hypot(middleMcp.x - wrist.x, middleMcp.y - wrist.y);

        const isOpen = (dTip8 > dMcp5 * 1.4) && (dTip12 > dMcp9 * 1.4);
        const isFist = (dTip8 < dMcp5 * 1.2) && (dTip12 < dMcp9 * 1.2);

        if (distPinch < 0.05) {
            currentGesture = 'Pinch';
        } else if (isFist) { 
            currentGesture = 'Fist';
        } else if (isOpen) {
            currentGesture = 'Open'; 
        } else {
            currentGesture = 'None'; 
        }

        AppState.hand.gesture = currentGesture;
        document.getElementById('gesture-text').innerText = currentGesture;

        if (AppState.currentScene === 0) handleIntroInteraction(cursorX, cursorY);
        else {
            handleUIInteraction(cursorX, cursorY);
            if (AppState.currentScene === 1) {
                if (AppState.scene1EntranceProgress > 0.95) {
                    if (currentGesture === 'Fist') AppState.sceneProgress[1] += 0.01;
                    else AppState.sceneProgress[1] -= 0.015; 
                } else {
                    AppState.sceneProgress[1] -= 0.05; 
                }
                AppState.sceneProgress[1] = THREE.MathUtils.clamp(AppState.sceneProgress[1], 0, 1);
            } else if (AppState.currentScene === 2) {
                if (AppState.scene2EntranceProgress > 0.98) {
                    if (currentGesture === 'Open') {
                        AppState.sceneProgress[2] += 0.015; 
                    } else {
                        AppState.sceneProgress[2] -= 0.02;  
                    }
                    AppState.sceneProgress[2] = THREE.MathUtils.clamp(AppState.sceneProgress[2], 0, 1);
                } else {
                    AppState.sceneProgress[2] = 0;
                }
            }
        }
    } else {
        document.getElementById('tracking-status').classList.remove('active');
        AppState.hand.detected = false; handCursor.style.opacity = 0;
        AppState.hand.pinchStartY = 0;
        if(AppState.currentScene === 1) AppState.sceneProgress[1] = THREE.MathUtils.lerp(AppState.sceneProgress[1], 0, 0.01);
        if(AppState.currentScene === 2) AppState.sceneProgress[2] = THREE.MathUtils.lerp(AppState.sceneProgress[2], 0, 0.05);
        if(AppState.currentScene === 0) resetHoverState();
        if(AppState.currentScene > 0) resetUIHoverState();
    }
}

function handleIntroInteraction(cursorX, cursorY) {
    if (!AppState.introAwaked) {
        AppState.introAwaked = true;
        const introTitle = document.querySelector('.intro-title');
        if (introTitle) introTitle.style.transform = 'translateY(-150px) scale(0.6)';
        const introSubtitle = document.querySelector('.intro-subtitle');
        if (introSubtitle) introSubtitle.style.transform = 'translateY(-150px) scale(0.6)';
        const introPrompt = document.getElementById('intro-prompt');
        if (introPrompt) introPrompt.style.opacity = 0;
        const nodesContainer = document.getElementById('nodes-container');
        if (nodesContainer) {
            nodesContainer.style.opacity = 1;
            nodesContainer.style.pointerEvents = 'auto';
        }
        playBGM(); 
        VoiceManager.speak("这里，是水开始的地方...... 也是时间流经的路径。请移动双手悬停星轨节点，进入水的数字记忆之中。");
        return;
    }
    let hoveringNodeId = null;
    document.querySelectorAll('.node-item').forEach(node => {
        const rect = node.getBoundingClientRect();
        if (cursorX > rect.left && cursorX < rect.right && cursorY > rect.top && cursorY < rect.bottom) hoveringNodeId = parseInt(node.dataset.id);
    });
    if (hoveringNodeId) {
        if (AppState.hoverState.targetNode !== hoveringNodeId) {
            resetHoverState(); 
            AppState.hoverState.targetNode = hoveringNodeId;
            const el = document.getElementById(`node-${hoveringNodeId}`);
            if (el) { el.style.borderColor = 'var(--primary-color)'; el.style.color = 'var(--primary-color)'; }
            if (handCursor) handCursor.style.transform = 'translate(-50%, -50%) scale(1.5)';
        }
        AppState.hoverState.progress += 0.02;
        const progEl = document.getElementById(`node-prog-${hoveringNodeId}`);
        if (progEl) {
            progEl.style.opacity = AppState.hoverState.progress;
            progEl.style.transform = `rotate(${AppState.hoverState.progress * 360 - 90}deg)`;
        }
        if (AppState.hoverState.progress >= 1.0) enterScene(hoveringNodeId);
    } else {
        resetHoverState();
    }
}

function resetHoverState() {
    if (AppState.hoverState.targetNode) {
        const el = document.getElementById(`node-${AppState.hoverState.targetNode}`);
        if (el) { el.style.borderColor = 'rgba(0, 255, 204, 0.3)'; el.style.color = 'rgba(255, 255, 255, 0.5)'; }
        const progEl = document.getElementById(`node-prog-${AppState.hoverState.targetNode}`);
        if (progEl) progEl.style.opacity = 0;
    }
    AppState.hoverState.targetNode = null; AppState.hoverState.progress = 0;
    if (handCursor) handCursor.style.transform = 'translate(-50%, -50%) scale(1)';
}

function handleUIInteraction(cursorX, cursorY) {
    let hoveringBtnId = null;
    document.querySelectorAll('.nav-btn').forEach(btn => {
        const rect = btn.getBoundingClientRect();
        if (cursorX > rect.left && cursorX < rect.right && cursorY > rect.top && cursorY < rect.bottom) hoveringBtnId = btn.id;
    });
    if (hoveringBtnId) {
        if (AppState.uiHoverState.targetBtn !== hoveringBtnId) {
            resetUIHoverState(); AppState.uiHoverState.targetBtn = hoveringBtnId;
            document.getElementById(hoveringBtnId).style.borderColor = 'var(--primary-color)';
            handCursor.style.transform = 'translate(-50%, -50%) scale(1.5)';
        }
        AppState.uiHoverState.progress += 0.02;
        const btn = document.getElementById(hoveringBtnId);
        btn.style.background = `linear-gradient(90deg, rgba(0,255,204,0.4) ${AppState.uiHoverState.progress * 100}%, rgba(0,0,0,0.6) ${AppState.uiHoverState.progress * 100}%)`;
        if (AppState.uiHoverState.progress >= 1.0) {
            if (hoveringBtnId === 'btn-home') returnToHome();
            else goToNextScene();
            resetUIHoverState();
        }
    } else resetUIHoverState();
}

function resetUIHoverState() {
    if (AppState.uiHoverState.targetBtn) {
        const btn = document.getElementById(AppState.uiHoverState.targetBtn);
        if (btn) { btn.style.borderColor = 'rgba(0, 255, 204, 0.4)'; btn.style.background = 'rgba(0, 0, 0, 0.6)'; }
    }
    AppState.uiHoverState.targetBtn = null; AppState.uiHoverState.progress = 0;
    handCursor.style.transform = 'translate(-50%, -50%) scale(1)';
}

function enterScene(sceneId) {
    AppState.currentScene = sceneId;
    document.getElementById('intro-layer').style.opacity = 0;
    document.getElementById('intro-layer').style.pointerEvents = 'none';
    setTimeout(() => { document.getElementById('ui-layer').style.opacity = 1; document.getElementById('ui-layer').style.pointerEvents = 'auto'; }, 500);
    const meta = SceneData.find(s => s.id === sceneId);
    document.getElementById('unit-id-tag').innerText = `UNIT 0${sceneId}`;
    document.getElementById('unit-name-text').innerText = meta.name;
    document.getElementById('scene-title').innerText = `- ${meta.name} -`;
    document.getElementById('btn-next').innerHTML = sceneId === 7 ? '返回中枢 ⏏' : '下一单元 ⏭';
    if (sceneId === 1 || sceneId === 2) {
        if (sceneId === 1) {
            AppState.scene1EntranceProgress = 0; AppState.scene1NarrationState = 0;
            AppState.scene1SuccessSpoken = false; AppState.scene1CurrentText = ""; 
        } else {
            AppState.scene2EntranceProgress = 0; AppState.scene2NarrationState = 0;
            AppState.scene2SuccessSpoken = false; AppState.scene2CurrentText = ""; 
        }
        document.getElementById('subtitle-text').innerText = ""; 
        VoiceManager.speakSequence(meta.descLines, (lineText) => {
            if (sceneId === 1) AppState.scene1CurrentText = lineText; 
            else if (sceneId === 2) AppState.scene2CurrentText = lineText; 
            document.getElementById('subtitle-text').innerText = lineText;
        });
    } else {
        document.getElementById('subtitle-text').innerText = meta.desc;
        VoiceManager.speak(meta.desc);
    }
    for(let i=1; i<=7; i++) sceneGroups[i].visible = (i === sceneId);
    AppState.waterOpacityTarget = (sceneId === 2) ? 0.0 : 0.15;
    AppState.waterZTarget = -30; 
    updateBGM();
}

function returnToHome() {
    AppState.currentScene = 0;
    VoiceManager.stop(); 
    document.getElementById('ui-layer').style.opacity = 0;
    document.getElementById('ui-layer').style.pointerEvents = 'none';
    setTimeout(() => { document.getElementById('intro-layer').style.opacity = 1; document.getElementById('intro-layer').style.pointerEvents = 'auto'; }, 500);
    for(let i=1; i<=7; i++) sceneGroups[i].visible = false;
    AppState.waterOpacityTarget = 1.0; AppState.waterZTarget = 0; 
    resetUIHoverState(); resetHoverState();
    updateBGM();
}

const hands = new Hands({locateFile: (file) => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`});
hands.setOptions({ maxNumHands: 1, modelComplexity: 1, minDetectionConfidence: 0.6, minTrackingConfidence: 0.5 });
hands.onResults(onResults);
const cameraMP = new Camera(videoElement, { onFrame: async () => { await hands.send({image: videoElement}); }, width: 1280, height: 720 });
cameraMP.start().then(() => { document.getElementById('loading').style.opacity = '0'; setTimeout(() => document.getElementById('loading').style.display = 'none', 1000); });

const clock = new THREE.Clock();
function animate() {
    requestAnimationFrame(animate);
    const time = clock.getElapsedTime();
    if (typeof AppState !== 'undefined' && globalWaterShaderMaterial) {
        globalWaterShaderMaterial.uniforms.u_time.value = time;
        AppState.waterOpacityCurrent = THREE.MathUtils.lerp(AppState.waterOpacityCurrent, AppState.waterOpacityTarget, 0.05);
        globalWaterShaderMaterial.uniforms.u_opacity.value = AppState.waterOpacityCurrent;
        AppState.waterZCurrent = THREE.MathUtils.lerp(AppState.waterZCurrent, AppState.waterZTarget, 0.03);
        if (globalWaterMesh) globalWaterMesh.position.z = AppState.waterZCurrent;
    }
    if (typeof AppState !== 'undefined' && AppState.currentScene === 1 && s1_particles) {
        AppState.scene1EntranceProgress = THREE.MathUtils.lerp(AppState.scene1EntranceProgress, 1.0, 0.005);
        const ep = AppState.scene1EntranceProgress;
        const easedEp = 1 - Math.pow(1 - ep, 4); 
        const attr = s1_particles.geometry.attributes.position;
        const orig = s1_particles.geometry.userData.originalPos;
        const target = s1_particles.geometry.userData.targetPos;
        const chaos = s1_particles.geometry.userData.chaosPos; 
        const p = AppState.sceneProgress[1];
        const subtitleText = document.getElementById('subtitle-text');
        if (p > 0.9 && AppState.scene1NarrationState === 0) {
            VoiceManager.stop(); 
            subtitleText.innerText = SceneData[0].descSuccess;
            if (!AppState.scene1SuccessSpoken) { VoiceManager.speak(SceneData[0].descSuccess); AppState.scene1SuccessSpoken = true; }
            AppState.scene1NarrationState = 1;
        } else if (p <= 0.9 && AppState.scene1NarrationState === 1) {
            subtitleText.innerText = AppState.scene1CurrentText;
            AppState.scene1NarrationState = 0;
        }
        if (s1_labelDom && s1_labelObj) {
            s1_labelObj.updateMatrixWorld(true);
            const vec = new THREE.Vector3(); s1_labelObj.getWorldPosition(vec); vec.project(camera);
            s1_labelDom.style.left = `${(vec.x * .5 + .5) * window.innerWidth}px`;
            s1_labelDom.style.top = `${(vec.y * -.5 + .5) * window.innerHeight}px`;
            s1_labelDom.style.opacity = p; 
            s1_labelDom.style.transform = `translate(-50%, calc(-50% - ${(1 - p) * 20}px))`; 
        }
        s1_particles.material.opacity = (0.2 + 0.3 * easedEp) + p * 0.5; 
        for(let i=0; i < attr.count; i++) {
            const idx = i * 3;
            const baseX = THREE.MathUtils.lerp(chaos[idx], orig[idx], easedEp);
            const baseY = THREE.MathUtils.lerp(chaos[idx+1], orig[idx+1], easedEp);
            const baseZ = THREE.MathUtils.lerp(chaos[idx+2], orig[idx+2], easedEp);
            const flowX = Math.sin(time * 0.5 + orig[idx+1] * 0.5) * 0.2 * (1 - p) * easedEp;
            const flowY = Math.cos(time * 0.4 + orig[idx] * 0.5) * 0.2 * (1 - p) * easedEp;
            const flowZ = Math.sin(time * 0.6 + orig[idx+2] * 0.5) * 0.2 * (1 - p) * easedEp;
            attr.array[idx] = THREE.MathUtils.lerp(baseX, target[idx], p) + flowX;
            attr.array[idx+1] = THREE.MathUtils.lerp(baseY, target[idx+1], p) + flowY;
            attr.array[idx+2] = THREE.MathUtils.lerp(baseZ, target[idx+2], p) + flowZ;
        }
        attr.needsUpdate = true; sceneGroups[1].rotation.y = (1 - easedEp) * Math.PI;
    }
    if (typeof AppState !== 'undefined' && AppState.currentScene === 2) {
        AppState.scene2EntranceProgress = THREE.MathUtils.lerp(AppState.scene2EntranceProgress, 1.0, 0.003); 
        const ep2 = AppState.scene2EntranceProgress;
        const p = AppState.sceneProgress[2];
        const subtitleText = document.getElementById('subtitle-text');
        
        if (p > 0.6 && AppState.scene2NarrationState === 0) {
            VoiceManager.stop(); 
            subtitleText.innerText = SceneData[1].descSuccess;
            if (!AppState.scene2SuccessSpoken) { VoiceManager.speak(SceneData[1].descSuccess); AppState.scene2SuccessSpoken = true; }
            AppState.scene2NarrationState = 1;
        } else if (p <= 0.6 && AppState.scene2NarrationState === 1) {
            subtitleText.innerText = AppState.scene2CurrentText;
            AppState.scene2NarrationState = 0;
        }

        if (s2_patternParticles) {
            s2_patternParticles.material.uniforms.u_progress.value = ep2;
            s2_patternParticles.material.uniforms.u_dissolve.value = p; 
            s2_patternParticles.material.uniforms.u_time.value = time;
            const sweep = 1.0 - Math.pow(1.0 - ep2, 4.0); 
            sceneGroups[2].scale.setScalar(1.0 + sweep * 0.3); 
            sceneGroups[2].rotation.z = (1.0 - sweep) * Math.PI * 0.25; 
            sceneGroups[2].rotation.x = (1.0 - sweep) * Math.PI * 0.25;
            sceneGroups[2].rotation.y = (1.0 - sweep) * Math.PI * 0.5 + Math.sin(time * 0.2) * 0.05; 
        }

        const bronzeOpacity = p;
        s2_parts.forEach((part, index) => {
            part.material.opacity = bronzeOpacity;
            part.material.transparent = true; 
            part.visible = bronzeOpacity > 0.01; 
            part.position.lerpVectors(part.userData.targetPos, part.userData.origPos, Math.pow(p, 0.5)); 
            
            if (p > 0.1) {
                const vec = new THREE.Vector3(); part.getWorldPosition(vec); vec.project(camera);
                part.userData.domElement.style.left = `${(vec.x * .5 + .5) * window.innerWidth}px`;
                part.userData.domElement.style.top = `${(-vec.y * .5 + .5) * window.innerHeight}px`;
                part.userData.domElement.style.opacity = THREE.MathUtils.clamp((p - 0.2) * 2, 0, 1) * bronzeOpacity;
            } else { 
                part.userData.domElement.style.opacity = 0; 
            }
        });
    }
    renderer.render(scene, camera);
}
animate();
window.addEventListener('resize', () => { camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix(); renderer.setSize(window.innerWidth, window.innerHeight); });
</script>
</body>
