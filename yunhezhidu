// ==========================================
// 数字水脉 Shader
// ==========================================
let globalWaterShaderMaterial;
let globalWaterMesh;

function buildGlobalWaterVein() {
    const particleCount = 200000;
    const geometry = new THREE.BufferGeometry();
    const positions = new Float32Array(particleCount * 3);
    const uvs = new Float32Array(particleCount * 2);

    for(let i=0; i<particleCount; i++) {
        positions[i*3] = (Math.random() - 0.5) * 120; 
        const yDist = (Math.random() - 0.5);
        positions[i*3+1] = yDist * yDist * 40 * Math.sign(yDist); 
        positions[i*3+2] = (Math.random() - 0.5) * 20 - 3; 
        uvs[i*2] = Math.random();
        uvs[i*2+1] = Math.random();
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('uv', new THREE.BufferAttribute(uvs, 2));

    globalWaterShaderMaterial = new THREE.ShaderMaterial({
        uniforms: {
            u_time: { value: 0.0 },
            u_colorBase: { value: new THREE.Color(0x001155) },
            u_colorCrest: { value: new THREE.Color(0x00ffcc) },
            u_pixelRatio: { value: Math.min(window.devicePixelRatio, 2.0) },
            u_opacity: { value: 1.0 }
        },
        vertexShader: `
            uniform float u_time;
            uniform float u_pixelRatio;
            varying float vElevation;
            void main() {
                vec4 modelPosition = modelMatrix * vec4(position, 1.0);
                float speed = 0.5; 
                modelPosition.x += u_time * speed;
                modelPosition.x = mod(modelPosition.x + 60.0, 120.0) - 60.0;
                float mainTide = sin(modelPosition.x * 0.05 - u_time * 0.8) * 4.0; 
                float subWave = cos(modelPosition.z * 0.15 + u_time * 0.6) * 2.5;
                float ripples = sin(modelPosition.x * 0.3 + modelPosition.y * 0.2 - u_time * 1.5) * 0.5; 
                float elevation = mainTide + subWave + ripples;
                modelPosition.y += elevation;
                modelPosition.z += sin(modelPosition.x * 0.1 - u_time * 0.4) * 1.5;
                vElevation = elevation;
                vec4 viewPosition = viewMatrix * modelPosition;
                gl_Position = projectionMatrix * viewPosition;
                gl_PointSize = (50.0 / -viewPosition.z) * (elevation * 0.05 + 1.1) * u_pixelRatio;
            }
        `,
        fragmentShader: `
            uniform vec3 u_colorBase;
            uniform vec3 u_colorCrest;
            uniform float u_opacity;
            varying float vElevation;
            void main() {
                float dist = distance(gl_PointCoord, vec2(0.5));
                if(dist > 0.5) discard;
                float core = smoothstep(0.2, 0.0, dist);
                float glow = pow(1.0 - (dist * 2.0), 2.0); 
                float strength = core * 0.7 + glow * 0.4;
                float mixValue = clamp((vElevation + 3.0) / 8.0, 0.0, 1.0);
                vec3 finalColor = mix(u_colorBase, u_colorCrest, mixValue);
                gl_FragColor = vec4(finalColor * 1.3, strength * u_opacity);
            }
        `,
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false
    });

    globalWaterMesh = new THREE.Points(geometry, globalWaterShaderMaterial);
    scene.add(globalWaterMesh); 
}
