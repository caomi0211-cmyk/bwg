let s1_labelObj;

function buildScene1() {
    const placeholderCount = 10;
    const geom = new THREE.BufferGeometry();
    geom.setAttribute('position', new THREE.BufferAttribute(new Float32Array(placeholderCount * 3), 3));
    geom.setAttribute('color', new THREE.BufferAttribute(new Float32Array(placeholderCount * 3), 3));
    geom.userData.originalPos = new Float32Array(placeholderCount * 3);
    geom.userData.targetPos = new Float32Array(placeholderCount * 3);
    
    s1_particles = new THREE.Points(geom, new THREE.PointsMaterial({ 
        size: 0.035, 
        map: sharedPointTexture,
        vertexColors: true, 
        transparent: true, 
        opacity: 0.85, 
        blending: THREE.AdditiveBlending,
        depthWrite: false 
    }));
    sceneGroups[1].add(s1_particles);

    const loader = new THREE.GLTFLoader();
    const loadModel = (url) => new Promise((resolve) => loader.load(url, resolve));

    function sampleSurfacePointCloud(geometry, matrixWorld, pointsArray, targetCount) {
        const posAttr = geometry.attributes.position;
        const indexAttr = geometry.index;
        if (!posAttr) return;

        const vA = new THREE.Vector3(); const vB = new THREE.Vector3(); const vC = new THREE.Vector3();
        const numFaces = indexAttr ? indexAttr.count / 3 : posAttr.count / 3;
        if (numFaces === 0) return;

        for (let i = 0; i < targetCount; i++) {
            const faceIdx = Math.floor(Math.random() * numFaces);
            let a, b, c;
            if (indexAttr) {
                a = indexAttr.getX(faceIdx * 3); b = indexAttr.getX(faceIdx * 3 + 1); c = indexAttr.getX(faceIdx * 3 + 2);
            } else {
                a = faceIdx * 3; b = faceIdx * 3 + 1; c = faceIdx * 3 + 2;
            }

            vA.fromBufferAttribute(posAttr, a);
            vB.fromBufferAttribute(posAttr, b);
            vC.fromBufferAttribute(posAttr, c);

            let r1 = Math.random(); let r2 = Math.random();
            if (r1 + r2 > 1) { r1 = 1 - r1; r2 = 1 - r2; }
            const r3 = 1 - r1 - r2;

            const pt = new THREE.Vector3(
                vA.x * r1 + vB.x * r2 + vC.x * r3,
                vA.y * r1 + vB.y * r2 + vC.y * r3,
                vA.z * r1 + vB.z * r2 + vC.z * r3
            ).applyMatrix4(matrixWorld);

            pointsArray.push(pt);
        }
    }

    Promise.all([
        loadModel('https://cdn.jsdelivr.net/gh/caomi0211-cmyk/bwg@main/c586594e1642672e0a11b4aa9e2c565b-v1.glb'), 
        loadModel('https://cdn.jsdelivr.net/gh/caomi0211-cmyk/bwg@main/qingliangang-v1.glb') 
    ]).then(([gltfStart, gltfEnd]) => {
        
        const model = gltfEnd.scene;
        const box = new THREE.Box3().setFromObject(model);
        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z);
        const scale = 8.0 / maxDim; 
        
        model.scale.setScalar(scale);
        model.position.sub(center.multiplyScalar(scale)); 
        model.updateMatrixWorld(true);
        
        const targetPositions = [];
        model.traverse((child) => {
            if (child.isMesh && !child.userData.isWireframe) {
                sampleSurfacePointCloud(child.geometry, child.matrixWorld, targetPositions, 100000);
            }
        });

        s1_labelObj = new THREE.Object3D();
        s1_labelObj.position.set(0, 2.8, 0); 
        sceneGroups[1].add(s1_labelObj);

        const div = document.createElement('div');
        div.className = 'artifact-label';
        div.style.borderColor = 'var(--primary-color)';
        div.style.color = 'var(--primary-color)';
        div.style.boxShadow = '0 0 10px rgba(0,255,204,0.3)';
        div.style.letterSpacing = '2px';
        div.style.fontSize = '14px';
        div.innerHTML = `<strong>青莲岗文化遗址陶器</strong>`;
        document.getElementById('labels-container').appendChild(div);
        s1_labelDom = div;

        const modelStart = gltfStart.scene;
        const boxStart = new THREE.Box3().setFromObject(modelStart);
        const sizeStart = boxStart.getSize(new THREE.Vector3());
        const centerStart = boxStart.getCenter(new THREE.Vector3());
        const maxDimStart = Math.max(sizeStart.x, sizeStart.y, sizeStart.z);
        const scaleStart = 10.0 / maxDimStart; 
        
        const pivotStart = new THREE.Group();
        modelStart.position.sub(centerStart);
        pivotStart.add(modelStart);
        pivotStart.scale.setScalar(scaleStart);
        pivotStart.position.y += 1.0; 
        pivotStart.rotation.set(Math.PI / 6, -Math.PI / 4, 0); 
        pivotStart.updateMatrixWorld(true);

        const startPositions = [];
        modelStart.traverse((child) => {
            if (child.isMesh) {
                sampleSurfacePointCloud(child.geometry, child.matrixWorld, startPositions, 100000);
            }
        });

        const pCount = targetPositions.length;
        const sCount = startPositions.length;
        const maxCount = Math.max(pCount, sCount); 
        if(maxCount === 0) return; 

        const positions = new Float32Array(maxCount * 3);
        const originalPosArray = new Float32Array(maxCount * 3); 
        const targetPosArray = new Float32Array(maxCount * 3);
        const chaosPosArray = new Float32Array(maxCount * 3);    
        const colors = new Float32Array(maxCount * 3);
        const colorObj = new THREE.Color();

        for(let i=0; i<maxCount; i++) {
            let startV = sCount > 0 ? startPositions[i % sCount] : new THREE.Vector3();
            let targetV = pCount > 0 ? targetPositions[i % pCount] : new THREE.Vector3();

            originalPosArray[i*3] = startV.x + (Math.random() - 0.5) * 0.15;
            originalPosArray[i*3+1] = startV.y + (Math.random() - 0.5) * 0.15;
            originalPosArray[i*3+2] = startV.z + (Math.random() - 0.5) * 0.15;

            chaosPosArray[i*3] = (Math.random() - 0.5) * 80;
            chaosPosArray[i*3+1] = (Math.random() - 0.5) * 80;
            chaosPosArray[i*3+2] = (Math.random() - 0.5) * 80;

            positions[i*3] = chaosPosArray[i*3];
            positions[i*3+1] = chaosPosArray[i*3+1];
            positions[i*3+2] = chaosPosArray[i*3+2];

            targetPosArray[i*3] = targetV.x;
            targetPosArray[i*3+1] = targetV.y;
            targetPosArray[i*3+2] = targetV.z;

            const yRatio = THREE.MathUtils.clamp((targetV.y + 4.0) / 8.0, 0, 1);
            colorObj.setHSL(0.55 - yRatio * 0.12, 0.9, 0.4 + yRatio * 0.4);
            colors[i*3] = colorObj.r; colors[i*3+1] = colorObj.g; colors[i*3+2] = colorObj.b;
        }

        const geometry = new THREE.BufferGeometry();
        geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
        geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
        geometry.userData.originalPos = originalPosArray; 
        geometry.userData.targetPos = targetPosArray;      
        geometry.userData.chaosPos = chaosPosArray; 

        sceneGroups[1].remove(s1_particles);
        s1_particles = new THREE.Points(geometry, s1_particles.material);
        sceneGroups[1].add(s1_particles);
    });
}

// ==========================================
// 场景2 (楚韵汉风) - 高级 GPU 着色器粒子阵列
// ==========================================
const s2_parts = [];
let s2_patternParticles = null; 

function buildScene2() {
    const group = sceneGroups[2];

    // 【排版大重构】：删除所有外围图腾，只保留正中央 1 个大幅放大的核心图腾
    const patternUrls = [
        'https://cdn.jsdelivr.net/gh/caomi0211-cmyk/bwg@main/2.10wen.png' // 唯一核心阵眼 (中)
    ];

    // 【防卡死核心】：加入 onerror 异常捕捉机制！
    const loadImgSafe = (url) => new Promise((resolve) => {
        const img = new Image();
        img.crossOrigin = 'Anonymous';
        img.onload = () => resolve(img);
        img.onerror = () => {
            console.warn("图片加载超时或失败，已启用安全回退机制: " + url);
            const fallbackCanvas = document.createElement('canvas');
            fallbackCanvas.width = 1; fallbackCanvas.height = 1;
            resolve(fallbackCanvas);
        };
        img.src = url;
    });

    Promise.all(patternUrls.map(loadImgSafe)).then((imgs) => {
        const startPositions = [];
        const targetPositions = [];
        const delays = [];
        const randoms = [];
        const patternIndices = []; 
        const isClones = [];       

        imgs.forEach((img, index) => {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            
            // 【提质增量1】：将横向最高采样分辨率从 400 提升到 600，提取更多原始细节
            let MAX_W = 600; 
            
            let w = img.width; let h = img.height;
            if (!w || !h || w === 0 || h === 0) return; 

            if (w > MAX_W) { h = Math.floor(h * (MAX_W / w)); w = MAX_W; }
            canvas.width = w; canvas.height = h;
            ctx.drawImage(img, 0, 0, w, h);
            const imgData = ctx.getImageData(0, 0, w, h).data;

            // 【物理放大】：将唯一的中心图腾物理高度从 5.0 大幅放大至 6.5
            let pHeight = 6.5; 
            
            const sc = pHeight / h;

            // 核心图腾采用逐像素密集采样，保证极致致密
            const step = 1; 
            const alphaThreshold = 60;

            // 【提质增量2】：大幅放开粒子数量封印！从 3.5万 提升至 8万，填充放大后的空间
            let pointsCount = 0;
            const MAX_POINTS = 80000;

            for(let y = 0; y < h; y+=step) {
                for(let x = 0; x < w; x+=step) {
                    const idx = (y * w + x) * 4;
                    const alpha = imgData[idx + 3];
                    
                    if (alpha > alphaThreshold && pointsCount < MAX_POINTS) { 
                        pointsCount++;
                        const localX = (x - w/2) * sc;
                        const localY = -(y - h/2) * sc;
                        const localZ = 0.0;

                        const pixelRandom = Math.random(); 

                        for (let t = 0; t < 2; t++) {
                            targetPositions.push(localX, localY, localZ);

                            const theta = Math.random() * Math.PI * 2;
                            const phi = Math.acos((Math.random() * 2.0) - 1.0);
                            const r = 60 + Math.random() * 40;
                            startPositions.push(
                                r * Math.sin(phi) * Math.cos(theta),
                                r * Math.sin(phi) * Math.sin(theta),
                                r * Math.cos(phi)
                            );

                            delays.push(t * 0.2); 
                            randoms.push(pixelRandom); 
                            
                            // 核心图腾固定分配到 aPatternIdx = 5.0
                            let staggerOrder = 5; 

                            patternIndices.push(staggerOrder);     
                            isClones.push(t === 0 ? 0.0 : 1.0); 
                        }
                    }
                }
            }
        });

        if (targetPositions.length > 0) {
            const geom = new THREE.BufferGeometry();
            geom.setAttribute('position', new THREE.Float32BufferAttribute(startPositions, 3));
            geom.setAttribute('targetPos', new THREE.Float32BufferAttribute(targetPositions, 3));
            geom.setAttribute('aDelay', new THREE.Float32BufferAttribute(delays, 1));
            geom.setAttribute('aRandom', new THREE.Float32BufferAttribute(randoms, 1));
            geom.setAttribute('aPatternIdx', new THREE.Float32BufferAttribute(patternIndices, 1)); 
            geom.setAttribute('aIsClone', new THREE.Float32BufferAttribute(isClones, 1));          

            const s2_shaderMaterial = new THREE.ShaderMaterial({
                uniforms: {
                    u_progress: { value: 0.0 }, 
                    u_dissolve: { value: 0.0 }, 
                    u_time: { value: 0.0 }
                },
                vertexShader: `
                    attribute vec3 targetPos;
                    attribute float aDelay;
                    attribute float aRandom;
                    attribute float aPatternIdx;
                    attribute float aIsClone;
                    
                    uniform float u_progress;
                    uniform float u_dissolve;
                    uniform float u_time;
                    
                    varying float vAlpha;
                    varying vec3 vColor;
                    varying float vIsClone;

                    void main() {
                        vIsClone = aIsClone;

                        float staggerStart = aPatternIdx * 0.09; 
                        float localProgress = clamp((u_progress - staggerStart) * 3.5, 0.0, 1.0);

                        float p_anim = clamp((localProgress * 1.5) - aDelay, 0.0, 1.0);
                        p_anim = 1.0 - pow(1.0 - p_anim, 4.0); 

                        // 唯一的核心阵眼，雄踞正中
                        vec3 currentCenter = vec3(0.0, 0.0, 0.5); 

                        vec3 finalTarget = currentCenter + targetPos;
                        vec3 pos = mix(position, finalTarget, p_anim);

                        float breath = (sin(u_time * 2.0 + aPatternIdx * 1.5) + 1.0) * 0.5; 
                        float floatMag = 0.005; 
                        pos.x += sin(u_time * 1.2 + aRandom * 10.0) * floatMag;
                        pos.y += cos(u_time * 1.5 + aRandom * 10.0) * floatMag;
                        pos.z += sin(u_time * 1.0 + aRandom * 10.0) * floatMag;

                        float swirlAngle = u_dissolve * (5.0 + aRandom * 2.0);
                        float s_swirl = sin(swirlAngle);
                        float c_swirl = cos(swirlAngle);
                        vec3 exitPos = pos;
                        exitPos.xy = mat2(c_swirl, -s_swirl, s_swirl, c_swirl) * exitPos.xy; 
                        exitPos = mix(exitPos, vec3(0.0, 0.0, -10.0), pow(u_dissolve, 1.5)); 
                        pos = mix(pos, exitPos, u_dissolve);

                        vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
                        gl_Position = projectionMatrix * mvPosition;

                        float sizeBreath = mix(0.9, 1.1, breath);
                        float baseSize = aIsClone == 0.0 ? 30.0 : 45.0;
                        
                        // 【画质微调】：因为物理尺寸更大了，点距变宽，适度回调粒子自身半径(0.75)保证线条不断裂
                        baseSize *= 0.75;

                        gl_PointSize = (baseSize / -mvPosition.z) * (1.0 - aDelay * 0.6) * (1.0 - u_dissolve) * sizeBreath;

                        vColor = mix(vec3(0.85, 0.60, 0.15), vec3(0.0, 0.9, 0.8), aRandom * p_anim);
                        float cloneFade = aIsClone == 0.0 ? 1.0 : (1.0 - smoothstep(0.8, 1.0, localProgress));
                        float alphaBreath = mix(0.6, 1.0, breath);
                        vAlpha = (1.0 - aDelay) * smoothstep(0.0, 0.2, p_anim) * cloneFade * (1.0 - u_dissolve) * alphaBreath;
                    }
                `,
                fragmentShader: `
                    varying float vAlpha;
                    varying vec3 vColor;
                    varying float vIsClone;

                    void main() {
                        vec2 coord = gl_PointCoord - vec2(0.5);
                        float dist = length(coord);
                        if(dist > 0.5) discard;
                        float core = vIsClone == 0.0 ? smoothstep(0.5, 0.35, dist) : smoothstep(0.5, 0.0, dist);
                        float intensity = vIsClone == 0.0 ? 0.8 : 1.2;
                        vec3 finalColor = vColor * core * intensity; 
                        gl_FragColor = vec4(finalColor, vAlpha * core);
                    }
                `,
                transparent: true,
                blending: THREE.AdditiveBlending,
                depthWrite: false
            });

            s2_patternParticles = new THREE.Points(geom, s2_shaderMaterial);
            group.add(s2_patternParticles);
        }
    }).catch(err => {
        console.error("图片资源网络获取严重崩溃: ", err);
    });

    const bronzeMat = new THREE.MeshStandardMaterial({ 
        color: 0xcd7f32, 
        metalness: 0.8, 
        roughness: 0.3, 
        transparent: true, 
        opacity: 0,
        depthWrite: true
    });
    
    const core = new THREE.Mesh(new THREE.CylinderGeometry(1.5, 1.8, 2.5, 8), bronzeMat);
    setupExplodePart(core, new THREE.Vector3(0, -6, 0), "主体腹部"); group.add(core); 
    
    const topMat = bronzeMat.clone();
    const top = new THREE.Mesh(new THREE.CylinderGeometry(1.8, 0.8, 1.0, 8), topMat);
    top.position.y = 1.75; setupExplodePart(top, new THREE.Vector3(0, 6, 0), "兽首纹盖"); group.add(top); 
}

